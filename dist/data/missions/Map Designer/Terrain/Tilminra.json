    "metadata": {
        "sysdescription": "Tilminra is a Terran-settled \u201cbreadbasket with teeth\u201d: sprawling agri-habitats and orbital processing plants feed nearby routes while a strong civic militia protects the supply chain. The system\u2019s secondary strength is frontier pharmacology\u2014bio-engineered organics and practical med supplies meant for hard living and long travel. Tilminra\u2019s culture is proud and communal, but strained: everyone knows a single serious disruption could turn abundance into panic.",
        "security": "Neutral",
        "exports": [
            "Agriculture",
            "Research",
            "Bio-Engineered Organics",
            "Medical Supplies"
        ],
        "focus": "Tourism & Culture",
